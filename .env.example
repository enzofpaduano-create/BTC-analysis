# ============================================================================
#  btc-quant — exemple de configuration locale
#  Copier ce fichier vers `.env` et remplir les valeurs. JAMAIS commit `.env`.
# ============================================================================

# -- Bybit ------------------------------------------------------------------
# Inscription : https://www.bybit.com (mainnet) ou https://testnet.bybit.com (testnet, gratuit, recommandé en dev)
# Générer une clé : Settings > API > Create New API Key (read-only suffit pour l'historique)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true     # true = paper trading, false = argent réel

# -- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR

# -- Stockage ---------------------------------------------------------------
# Racine du store local (Parquet partitionné + DuckDB).
DATA_DIR=./data_store
