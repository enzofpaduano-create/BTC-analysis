# ============================================================================
#  btc-quant — exemple de configuration locale
#  Copier ce fichier vers `.env` et remplir les valeurs. JAMAIS commit `.env`.
# ============================================================================

# -- Bybit ------------------------------------------------------------------
# Inscription : https://www.bybit.com (mainnet) ou https://testnet.bybit.com (testnet, gratuit, recommandé en dev)
# Générer une clé : Settings > API > Create New API Key (read-only suffit pour l'historique)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true     # true = paper trading, false = argent réel

# -- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR

# -- Stockage ---------------------------------------------------------------
# Racine du store local (Parquet partitionné + DuckDB).
DATA_DIR=./data_store

# -- Telegram (optionnel) ---------------------------------------------------
# 1) Crée un bot via @BotFather sur Telegram (/newbot), récupère le TOKEN.
# 2) Envoie un message à ton bot depuis ton compte Telegram.
# 3) Récupère ton chat_id :
#       curl https://api.telegram.org/bot<TOKEN>/getUpdates
#    Cherche "chat":{"id":...} dans la réponse.
# 4) Renseigne les valeurs ci-dessous. Si TELEGRAM_BOT_TOKEN ou
#    TELEGRAM_CHAT_ID est vide, le sink Telegram est désactivé silencieusement.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_SCORE_ABS=0.3   # n'alerte que quand |score| ≥ ce seuil
